# Google Sheets Configuration
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEET_NAME=Sheet1

# Folder Watching
WATCH_DIRECTORY=~/LinocutArchive

# Agent Configuration
ENABLE_METADATA_FILLER=true
ENABLE_COLOR_AGENT=true
ENABLE_TAG_AGENT=true
ENABLE_TOOLS_NORMALIZER=true

# LLM Configuration (requires API key)
ENABLE_LLM=false
LLM_PROVIDER=anthropic  # 'openai' or 'anthropic'
ENABLE_LLM_COLOR_AGENT=true
ENABLE_LLM_TAG_AGENT=true
# For OpenAI: OPENAI_API_KEY=your_openai_key_here
# For Anthropic: ANTHROPIC_API_KEY=your_anthropic_key_here

# Logging
LOG_LEVEL=INFO
LOG_FILE=linolog.log

# Processing
PROCESSED_LOG_FILE=processed_folders.txt 